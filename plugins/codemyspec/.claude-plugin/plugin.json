{
  "name": "codemyspec",
  "description": "Specification-driven development for Phoenix applications — design architecture, write specs, generate tests, and implement with specialized AI agents",
  "version": "1.5.38",
  "author": {
    "name": "CodeMySpec",
    "url": "https://codemyspec.com"
  },
  "license": "MIT",
  "homepage": "https://codemyspec.com",
  "repository": "https://github.com/Code-My-Spec/plugins",
  "keywords": [
    "phoenix",
    "elixir",
    "specification",
    "architecture",
    "tdd",
    "bdd",
    "code-generation",
    "liveview"
  ],
  "mcpServers": {
    "local": {
      "type": "stdio",
      "command": "cms-mcp-relay",
      "env": {
        "CLAUDE_PROJECT_DIR": "${CLAUDE_PROJECT_DIR}",
        "CMS_MCP_BASE_URL": "http://localhost:4003"
      }
    },
    "vibium": {
      "type": "stdio",
      "command": "vibium",
      "args": ["mcp"]
    }
  }
}
