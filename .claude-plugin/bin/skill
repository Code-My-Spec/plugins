#!/bin/bash
# Route a skill invocation to the local server
# Usage: skill <skill_name> <external_id> [subcommand] [module_name_or_args...]

SKILL="$1"
EXTERNAL_ID="$2"
SUBCMD="$3"
shift 3 2>/dev/null
MODULE_NAME="$*"

if [ -z "$SKILL" ] || [ -z "$EXTERNAL_ID" ]; then
  echo '{"error": "Usage: skill <skill_name> <external_id> [subcommand] [args...]"}'
  exit 1
fi

# Build JSON payload
PAYLOAD="{\"skill\": \"$SKILL\", \"external_id\": \"$EXTERNAL_ID\""

if [ -n "$SUBCMD" ]; then
  PAYLOAD="$PAYLOAD, \"subcommand\": \"$SUBCMD\""
fi

if [ -n "$MODULE_NAME" ]; then
  PAYLOAD="$PAYLOAD, \"module_name\": \"$MODULE_NAME\""
fi

PAYLOAD="$PAYLOAD}"

PORT="${CODEMYSPEC_PORT:-4003}"

curl -s -X POST "http://localhost:${PORT}/api/skills/start" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: $(pwd)" \
  -d "$PAYLOAD"
